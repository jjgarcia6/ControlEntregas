DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
TEST_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname_test  # Base de datos separada para tests
JWT_SECRET_KEY=cambiar-en-produccion
# REQUERIDA. Fernet key para cifrado de PII en columnas. Generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_LEEWAY_SECONDS=7200
CORS_ORIGINS=["http://localhost:5173"]
ENVIRONMENT=development
ADMIN_EMAIL=admin@sistema.com
ADMIN_PASSWORD=         # Sin default; requerida para ejecutar seed.py
